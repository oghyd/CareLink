<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="src.view.ShellController">

    <!-- Sidebar -->
    <left>
        <VBox fx:id="sidebar" spacing="8" prefWidth="200"
              style="-fx-background-color: #2c3e50;">
            <padding><Insets top="16" right="12" bottom="16" left="12"/></padding>

            <Label fx:id="nameLabel"
                   style="-fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold;"/>

            <Label fx:id="roleLabel"
                   style="-fx-text-fill: #bdc3c7; -fx-font-size: 12;"/>

            <Separator/>

            <!-- Student menu items -->
            <Button fx:id="btnMesDemandes"     text="Mes demandes"     onAction="#showMesDemandes"     maxWidth="Infinity" alignment="CENTER_LEFT" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 13; -fx-cursor: hand;"/>
            <Button fx:id="btnMesReclamations" text="Mes réclamations" onAction="#showMesReclamations" maxWidth="Infinity" alignment="CENTER_LEFT" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 13; -fx-cursor: hand;"/>
            <Button fx:id="btnMonProfil"       text="Mon profil"       onAction="#showMonProfil"       maxWidth="Infinity" alignment="CENTER_LEFT" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 13; -fx-cursor: hand;"/>

            <!-- Admin menu items -->
            <Button fx:id="btnTableauDeBord"   text="Tableau de bord"  onAction="#showTableauDeBord"   maxWidth="Infinity" alignment="CENTER_LEFT" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 13; -fx-cursor: hand;"/>
            <Button fx:id="btnComptes"         text="Comptes"          onAction="#showComptes"         maxWidth="Infinity" alignment="CENTER_LEFT" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 13; -fx-cursor: hand;"/>
            <Button fx:id="btnDemandes"        text="Demandes"         onAction="#showDemandes"        maxWidth="Infinity" alignment="CENTER_LEFT" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 13; -fx-cursor: hand;"/>
            <Button fx:id="btnReclamations"    text="Réclamations"     onAction="#showReclamations"    maxWidth="Infinity" alignment="CENTER_LEFT" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 13; -fx-cursor: hand;"/>
            <Button fx:id="btnHistorique"      text="Historique"       onAction="#showHistorique"      maxWidth="Infinity" alignment="CENTER_LEFT" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 13; -fx-cursor: hand;"/>

            <!-- pushe logout to bottom -->
            <Region VBox.vgrow="ALWAYS"/>

            <Button text="Déconnexion" onAction="#handleLogout"
                    maxWidth="Infinity"
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white;"/>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
        </StackPane>
    </center>

</BorderPane>