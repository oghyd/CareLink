<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            stylesheets="@../css/application.css"
            fx:controller="src.view.StudentComplaintsController">

    <top>
        <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="12">
            <Label text="Mes Réclamations" styleClass="screen-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="btnNouvelleReclamation" text="+ Nouvelle Réclamation" onAction="#handleNouvelleReclamation" styleClass="btn-primary"/>
        </HBox>
    </top>

    <center>
        <TableView fx:id="tableReclamations" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colObjet" text="Objet" prefWidth="250"/>
                <TableColumn fx:id="colStatut" text="Statut" prefWidth="150"/>
                <TableColumn fx:id="colDate" text="Date" prefWidth="150"/>
                <TableColumn fx:id="colActions" text="Actions" prefWidth="150"/>
            </columns>
        </TableView>
    </center>

    <right>
        <VBox fx:id="formPanel" styleClass="form-panel" prefWidth="320" visible="false" managed="false">
            <Label text="Nouvelle Réclamation" styleClass="form-title"/>

            <Label text="Objet"/>
            <TextField fx:id="fieldObjet" promptText="Objet de la réclamation"/>

            <Label text="Description"/>
            <TextArea fx:id="fieldDescription" promptText="Décrivez votre réclamation" prefRowCount="4"/>

            <Label fx:id="labelError" styleClass="error-label"/>

            <HBox spacing="8" alignment="CENTER_RIGHT">
                <Button fx:id="btnAnnuler" text="Annuler" onAction="#handleAnnuler" styleClass="btn-secondary"/>
                <Button fx:id="btnSubmitReclamation" text="Envoyer" onAction="#handleSubmit" styleClass="btn-primary"/>
            </HBox>
        </VBox>
    </right>

</BorderPane>