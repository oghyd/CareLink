<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>

<BorderPane xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="src.view.GestionComptesController">
   <center>
      <TableView fx:id="tableComptes" prefHeight="204.0" prefWidth="600.0" BorderPane.alignment="CENTER">
        <columns>
          <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
          <TableColumn fx:id="colNom" prefWidth="150.0" text="Nom" />
          <TableColumn fx:id="colPrenom" prefWidth="150.0" text="Prénom" />
          <TableColumn fx:id="colEmail" prefWidth="200.0" text="Email" />
          <TableColumn fx:id="colActif" prefWidth="100.0" text="Actif" />
        </columns>
      </TableView>
   </center>
   <bottom>
    <HBox spacing="10" alignment="CENTER" prefHeight="50.0" BorderPane.alignment="CENTER">
    <children>
        <Button fx:id="btnAjouter" mnemonicParsing="false" onAction="#handleAjouterCompte" text="Ajouter" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-cursor: hand;" />
        <Button fx:id="btnModifier" mnemonicParsing="false" onAction="#handleModifier" text="Modifier" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-cursor: hand;" />
        <Button fx:id="btnSupprimer" mnemonicParsing="false" onAction="#handleSupprimer" text="Supprimer" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-cursor: hand;" />
        <Button fx:id="btnDesactiver" mnemonicParsing="false" onAction="#handleDesactiver" text="Désactiver" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-cursor: hand;" />
        <Button fx:id="btnActiver" mnemonicParsing="false" onAction="#handleActiver" text="Activer" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-cursor: hand;" />
    </children>
</HBox>
</bottom>
</BorderPane>
