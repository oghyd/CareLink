<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="src.view.GestionReclamationsController">
   <center>
      <TableView fx:id="tableReclamations" prefHeight="400.0" prefWidth="800.0" BorderPane.alignment="CENTER">
        <columns>
          <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
          <TableColumn fx:id="colObjet" prefWidth="200.0" text="Objet" />
          <TableColumn fx:id="colDescription" prefWidth="300.0" text="Description" />
          <TableColumn fx:id="colStatut" prefWidth="100.0" text="Statut" />
          <TableColumn fx:id="colDateCreation" prefWidth="150.0" text="Date de création" />
        </columns>
      </TableView>
   </center>
   <bottom>
    <HBox spacing="10" alignment="CENTER" prefHeight="50.0" BorderPane.alignment="CENTER">
        <children>
            <Button fx:id="btnTraiter" mnemonicParsing="false" onAction="#handleTraiter" text="Traiter" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-cursor: hand;" />
            <Button fx:id="btnSupprimer" mnemonicParsing="false" onAction="#handleSupprimer" text="Supprimer" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-cursor: hand;" />
        </children>
    </HBox>
</bottom>
</BorderPane>